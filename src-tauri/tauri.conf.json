{
  "productName": "WebSocket Chat",
  "version": "1.2.1",
  "identifier": "com.websocketchat.app",
  "build": {
    "beforeBuildCommand": "bun run build:static",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "WebSocket Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "targets": ["deb", "appimage", "nsis", "msi"],
    "publisher": "WebSocket Chat",
    "homepage": "https://github.com/TheStrongestOfTomorrow/websocket-chat",
    "shortDescription": "Real-time WebSocket Chat",
    "longDescription": "A modern, real-time peer-to-peer chat application",
    "category": "Network;Chat;InstantMessaging",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
